set shell := ["bash", "-euo", "pipefail", "-c"]

root := justfile_directory() / ".."
schema := root / "target" / "ffier-ft.json"

# Run all tests
default: no-codegen check-header check-generated-client valgrind miri consumer compat cargo-test
    @echo ""
    @echo "All checks passed!"

# Build the test lib (also produces the cdylib + writes target/ffier-ft.json)
build:
    cargo build --manifest-path {{root}}/Cargo.toml -p ffier-test-lib

# Generate the C header
gen-header: build
    cargo run --manifest-path {{root}}/Cargo.toml -p ffier-gen-c-header -- {{schema}} > c/ffier_test.h

# Generate Rust client bindings source
gen-rust-client: build
    cargo run --manifest-path {{root}}/Cargo.toml -p ffier-gen-rust-client -- {{schema}} | rustfmt > lib-via-cdylib/src/generated.rs

# Update the expected header snapshot
update-expected-header: gen-header
    cp c/ffier_test.h expected_header.h

# Update the generated client bindings
update-generated-client: gen-rust-client

# Check header matches expected (byte-for-byte)
check-header: gen-header
    diff expected_header.h c/ffier_test.h

# Check generated client matches checked-in version
check-generated-client: gen-rust-client
    diff lib-via-cdylib/src/generated.rs <(cargo run --manifest-path {{root}}/Cargo.toml -p ffier-gen-rust-client -- {{schema}} 2>/dev/null | rustfmt)

# Compile and run the C tests
c: build gen-header
    cc -Wall -Wextra -Werror -g -o c/test_main c/test_main.c \
        -I c \
        -L {{root}}/target/debug \
        -lffier_test_lib \
        -Wl,-rpath,{{root}}/target/debug
    ./c/test_main

# Run C tests under valgrind
valgrind: c
    valgrind --leak-check=full --show-leak-kinds=all --track-origins=yes --error-exitcode=1 \
        ./c/test_main

# Run Miri with Stacked Borrows (default model)
miri-stacked:
    cargo +nightly miri test --manifest-path {{root}}/Cargo.toml -p ffier-test-lib

# Run Miri with Tree Borrows
miri-tree:
    MIRIFLAGS="-Zmiri-tree-borrows" cargo +nightly miri test --manifest-path {{root}}/Cargo.toml -p ffier-test-lib

# Run Miri with both memory models
miri: miri-stacked miri-tree

# Test consumer crate with native Rust linking
consumer-native: build
    cargo test --manifest-path {{root}}/Cargo.toml -p ffier-test-consumer --no-default-features --features native

# Test consumer crate with C ABI dynamic linking
consumer-cdylib: build
    cargo test --manifest-path {{root}}/Cargo.toml -p ffier-test-consumer --no-default-features --features via-cdylib

# Test consumer crate in both linking modes
consumer: consumer-native consumer-cdylib

# The v1 compat bindings (compat/src/generated_v1.rs) are a checked-in
# snapshot — they represent a v1 client without the fruit-label feature.
# The compat test verifies vtable backward compatibility by linking the
# v1 client against the current v2 library.

# Run vtable backward-compatibility tests (v1 client → v2 library)
compat: build
    cargo test --manifest-path {{root}}/Cargo.toml -p ffier-test-compat

# Verify the test lib compiles without FFI (no codegen, pure Rust types).
# Compilation alone proves no FFI symbols leak: library_definition! and
# all #[ffier::export] annotations are cfg-gated behind feature = "ffi".
no-codegen:
    cargo check --manifest-path {{root}}/Cargo.toml -p ffier-test-lib --no-default-features

# Run all Rust tests
cargo-test: build
    cargo test --manifest-path {{root}}/Cargo.toml
